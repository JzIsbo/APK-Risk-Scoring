APP_NAME="APK Risk Score"
APP_ENV=production
APP_KEY=                          # Run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-backend-domain.up.railway.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ──────────────────────────────────────────────
# DATABASE (MySQL on PlanetScale / Railway / etc.)
# ──────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=                          # e.g. containers-us-west-xxx.railway.app
DB_PORT=3306
DB_DATABASE=risk_scoring_db
DB_USERNAME=root
DB_PASSWORD=                      # Set your DB password

# ──────────────────────────────────────────────
# SANCTUM / CORS
# ──────────────────────────────────────────────
# Frontend Vercel URL(s) — separate multiple with commas
SANCTUM_STATEFUL_DOMAINS=your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@risk-dashboard.app"
MAIL_FROM_NAME="${APP_NAME}"
