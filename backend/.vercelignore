# Vercel ignore — jangan upload folder besar & file sensitif

# Dependencies (akan di-install saat build)
/vendor
node_modules

# Build artifacts lokal
/public/hot
/public/storage
/public/build

# Logs & storage runtime (dibuat fresh di serverless)
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*

# File sensitif lokal
.env
.env.backup
.env.local

# Test & dev tools
/tests
/.phpunit.cache
.phpunit.result.cache

# Git & editor
.git
.gitattributes
.editorconfig
.vscode
.idea

# OS files
.DS_Store
Thumbs.db
